{
  "openapi": "3.0.0",
  "info": {
    "title": "NSR-10 Struos API",
    "description": "Motor normativo de ingeniería estructural Colombia",
    "version": "1.3.0"
  },
  "servers": [
    {
      "url": "https://struos-api.vercel.app"
    }
  ],
  "paths": {
    "/municipios/{nombre}": {
      "get": {
        "operationId": "getParametrosSismicos",
        "summary": "Obtiene parámetros sísmicos Aa, Av y zona de amenaza para un municipio",
        "parameters": [
          {
            "name": "nombre",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Nombre del municipio sin tildes (Bogota, Medellin, Cali)"
          }
        ],
        "responses": {
          "200": {
            "description": "Municipios encontrados"
          }
        }
      }
    },
    "/coef/fa/{suelo}/{aa}": {
      "get": {
        "operationId": "getCoeficienteFa",
        "summary": "Obtiene coeficiente Fa segun tipo de suelo y Aa",
        "parameters": [
          {
            "name": "suelo",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tipo de suelo: A, B, C, D, E o F"
          },
          {
            "name": "aa",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Valor de Aa (0.05 a 0.50)"
          }
        ],
        "responses": {
          "200": {
            "description": "Coeficiente Fa"
          }
        }
      }
    },
    "/coef/fv/{suelo}/{av}": {
      "get": {
        "operationId": "getCoeficienteFv",
        "summary": "Obtiene coeficiente Fv segun tipo de suelo y Av",
        "parameters": [
          {
            "name": "suelo",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Tipo de suelo: A, B, C, D, E o F"
          },
          {
            "name": "av",
            "in": "path",
            "required": true,
            "schema": {
              "type": "number"
            },
            "description": "Valor de Av (0.05 a 0.50)"
          }
        ],
        "responses": {
          "200": {
            "description": "Coeficiente Fv"
          }
        }
      }
    },
    "/coef/r": {
      "get": {
        "operationId": "getCoeficienteR",
        "summary": "Obtiene coeficientes R0, Omega0 y Cd para sistemas estructurales",
        "parameters": [
          {
            "name": "sistema",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Tipo de sistema (portico, muro, dual)"
          },
          {
            "name": "capacidad",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Capacidad de disipacion: DES, DMO o DMI"
          }
        ],
        "responses": {
          "200": {
            "description": "Coeficientes R"
          }
        }
      }
    },
    "/barras": {
      "get": {
        "operationId": "getBarrasRefuerzo",
        "summary": "Obtiene propiedades de barras de refuerzo",
        "parameters": [
          {
            "name": "designacion",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            },
            "description": "Designacion de la barra (4, 5, 6, No.5, 16M)"
          }
        ],
        "responses": {
          "200": {
            "description": "Barras de refuerzo"
          }
        }
      }
    },
    "/deriva": {
      "get": {
        "operationId": "getDerivaMaxima",
        "summary": "Obtiene derivas maximas permitidas por sistema estructural",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Derivas maximas"
          }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "buscarSeccion",
        "summary": "Busca texto en las secciones de la NSR-10",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            },
            "description": "Texto a buscar"
          },
          {
            "name": "limit",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer"
            },
            "description": "Numero maximo de resultados"
          }
        ],
        "responses": {
          "200": {
            "description": "Secciones encontradas"
          }
        }
      }
    },
    "/ask": {
      "post": {
        "operationId": "preguntarNSR10",
        "summary": "Pregunta en lenguaje natural con RAG vectorial (pgvector cosine sobre 57k chunks)",
        "description": "Genera embedding de la pregunta, busca los top-k fragmentos mas similares en Supabase y responde citando [1], [2]. Retorna 'sources' con filename, pagina y similitud.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["query"],
                "properties": {
                  "query": {
                    "type": "string",
                    "description": "Pregunta tecnica en español",
                    "minLength": 3,
                    "maxLength": 500
                  },
                  "context_limit": {
                    "type": "integer",
                    "description": "Numero de fragmentos a recuperar (1-20)",
                    "default": 8,
                    "minimum": 1,
                    "maximum": 20
                  },
                  "folder": {
                    "type": "string",
                    "description": "Dominio a buscar. Default NSR-10.",
                    "enum": ["NSR-10", "AISC Design Guides", "Catálogos", "Manuales", "Normas técnicas"],
                    "default": "NSR-10"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Respuesta con citas"
          }
        }
      }
    },
    "/ask/folders": {
      "get": {
        "operationId": "listarFolders",
        "summary": "Lista los folders (dominios) disponibles para filtrar en /ask",
        "responses": {
          "200": {
            "description": "Lista de folders"
          }
        }
      }
    }
  }
}
