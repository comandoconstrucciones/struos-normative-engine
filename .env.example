# Motor Normativo NSR-10 — variables de entorno
# Copiar a .env y llenar con valores reales. NUNCA commitear .env.

# === Supabase ===
# Project: vdakfewjadwaczulcmvj
STRUOS_SUPABASE_URL=https://vdakfewjadwaczulcmvj.supabase.co
# IMPORTANTE: service_role bypasea RLS. Rotar en Supabase Dashboard
# y preferir anon key + RLS para endpoints públicos.
STRUOS_SUPABASE_SERVICE_ROLE=

# === OpenAI (endpoint /ask) ===
OPENAI_API_KEY=

# === API gating (opcional) ===
# Si se setea, los endpoints exigen header X-API-Key con este valor.
STRUOS_API_KEY=

# === CORS ===
# Coma-separados. Si vacío, se usa el default con dominios del proyecto + localhost.
ALLOWED_ORIGINS=https://struos-ai.vercel.app,https://struos-api.vercel.app,http://localhost:3000

# === Rate limiting (slowapi) ===
# Formato: "N/period" (ej: 60/minute, 1000/hour)
RATE_LIMIT=60/minute

# === MCP server ===
# URL del API que consultará el MCP server. Útil para self-hosting.
STRUOS_API_URL=https://struos-api.vercel.app
