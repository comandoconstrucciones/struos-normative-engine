  {
    "id": "formula_reduccion_L",
    "label": "Reducción Carga Viva",
    "tipo": "formula",
    "contenido": "L = Lo × (0.25 + 4.57/√AI)\nRef: B.4.5.1\nAI = área de influencia ≥ 37m²",
    "metadata": {}
  },
  {
    "id": "formula_presion_q",
    "label": "Presión por Velocidad",
    "tipo": "formula",
    "contenido": "qz = 0.613 × Kz × Kzt × Kd × V² × I\nRef: B.6.5.10\nqz en N/m², V en m/s",
    "metadata": {}
  },
  {
    "id": "formula_kz_formula",
    "label": "Coeficiente Kz",
    "tipo": "formula",
    "contenido": "Kz = 2.01 × (z/Zg)^(2/α)\nRef: B.6.5-3\nPara z ≥ 4.0m",
    "metadata": {}
  },
  {
    "id": "formula_presion_viento",
    "label": "Presión de Viento",
    "tipo": "formula",
    "contenido": "p = q × G × Cp - qi × (GCpi)\nRef: B.6.5.12\nG=factor ráfaga, Cp=coef presión",
    "metadata": {}
  },
