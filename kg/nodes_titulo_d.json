    "id": "formula_Vm",
    "label": "Cortante mampostería",
    "tipo": "formula",
    "contenido": "Vm = 0.30*Amv*sqrt(f'm) + 0.25*Pu\nMu/(Vu*d) <= 0.25",
    "metadata": {}
  },
  {
    "id": "formula_Pn",
    "label": "Carga axial nominal",
    "tipo": "formula",
    "contenido": "Pn = 0.80*[0.85*f'm*(An-As) + fy*As]\nCapacidad axial",
    "metadata": {}
  },
